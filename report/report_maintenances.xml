<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_maintenances"
            model="ir.actions.report">
        <field name="name">Rapport des maintenances</field>
        <field name="model">it.intervention</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_maintenances_document</field>
        <field name="report_file">it_parc.report_maintenances_document</field>
        <field name="binding_model_id" 
               ref="model_it_intervention"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_maintenances_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 class="text-center"
                        style="color:#1a3c5e;">
                        RAPPORT DES MAINTENANCES
                    </h2>
                    <hr/>

                    <table class="table table-bordered table-sm">
                        <thead style="background:#1a3c5e; color:white;">
                            <tr>
                                <th>Référence</th>
                                <th>Équipement</th>
                                <th>Type</th>
                                <th>Technicien</th>
                                <th>Date début</th>
                                <th>Date fin</th>
                                <th>Durée (h)</th>
                                <th>Coût (FCFA)</th>
                                <th>État</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="doc">
                                <tr>
                                    <td>
                                        <t t-esc="doc.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.equipement_id.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.type_intervention"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.technicien_id.name or '-'"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.date_debut"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.date_fin or '-'"/>
                                    </td>
                                    <td>
                                        <t t-esc="'{:.1f}'.format(doc.duree)"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'{:,.0f}'.format(doc.cout)"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.state"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="6">
                                    <strong>
                                        Total interventions :
                                        <t t-esc="len(docs)"/>
                                    </strong>
                                </td>
                                <td>
                                    <strong>
                                        <t t-esc="'{:.1f}'.format(sum(docs.mapped('duree')))"/> h
                                    </strong>
                                </td>
                                <td class="text-right">
                                    <strong>
                                        <t t-esc="'{:,.0f}'.format(sum(docs.mapped('cout')))"/> FCFA
                                    </strong>
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>

                    <div class="row mt-4">
                        <div class="col-12 text-right">
                            <small class="text-muted">
                                TECHPARK CI - Imprimé le
                                <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y à %H:%M')"/>
                            </small>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
