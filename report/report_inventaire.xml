<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_inventaire"
            model="ir.actions.report">
        <field name="name">Rapport d'inventaire</field>
        <field name="model">it.equipement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_inventaire_document</field>
        <field name="report_file">it_parc.report_inventaire_document</field>
        <field name="binding_model_id" 
               ref="model_it_equipement"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_inventaire_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 class="text-center"
                        style="color:#1a3c5e;">
                        RAPPORT D'INVENTAIRE INFORMATIQUE
                    </h2>
                    <p class="text-center text-muted">
                        TECHPARK CI - Abidjan-Cocody
                    </p>
                    <hr/>

                    <table class="table table-bordered table-sm">
                        <thead style="background:#1a3c5e; color:white;">
                            <tr>
                                <th>Référence</th>
                                <th>Nom</th>
                                <th>Catégorie</th>
                                <th>Marque</th>
                                <th>N° Série</th>
                                <th>Employé</th>
                                <th>Département</th>
                                <th>État</th>
                                <th>Fin garantie</th>
                                <th>Valeur (FCFA)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="doc">
                                <tr>
                                    <td>
                                        <t t-esc="doc.reference"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="dict(doc._fields['categorie'].selection).get(doc.categorie)"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.marque or '-'"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.numero_serie or '-'"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.employee_id.name or '-'"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.department_id.name or '-'"/>
                                    </td>
                                    <td>
                                        <t t-esc="dict(doc._fields['state'].selection).get(doc.state)"/>
                                    </td>
                                    <td>
                                        <t t-esc="doc.date_garantie or '-'"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'{:,.0f}'.format(doc.valeur_achat)"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="9">
                                    <strong>
                                        Total équipements :
                                        <t t-esc="len(docs)"/>
                                    </strong>
                                </td>
                                <td class="text-right">
                                    <strong>
                                        <t t-esc="'{:,.0f}'.format(sum(docs.mapped('valeur_achat')))"/> FCFA
                                    </strong>
                                </td>
                            </tr>
                        </tfoot>
                    </table>

                    <div class="row mt-4">
                        <div class="col-12 text-right">
                            <small class="text-muted">
                                Imprimé le
                                <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y à %H:%M')"/>
                            </small>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
