<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_it_contrat_list" 
            model="ir.ui.view">
        <field name="name">it.contrat.list</field>
        <field name="model">it.contrat</field>
        <field name="arch" type="xml">
            <list string="Contrats">
                <field name="name"/>
                <field name="fournisseur_id"/>
                <field name="type_contrat"/>
                <field name="date_debut"/>
                <field name="date_fin"/>
                <field name="montant"/>
                <field name="jours_restants"
                       decoration-danger="jours_restants &lt; 30"
                       decoration-warning="jours_restants &lt; 60"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-danger="state == 'expired'"
                       decoration-info="state == 'renewed'"/>
            </list>
        </field>
    </record>

    <record id="view_it_contrat_form" 
            model="ir.ui.view">
        <field name="name">it.contrat.form</field>
        <field name="model">it.contrat</field>
        <field name="arch" type="xml">
            <form string="Contrat fournisseur">
                <header>
                    <field name="state"
                           widget="statusbar"
                           options="{'clickable': 1}"
                           statusbar_visible="expired"
                           invisible="state != 'active'"/>
                    <field name="state"
                           widget="statusbar"
                           options="{'clickable': 1}"
                           statusbar_visible="renewed"
                           invisible="state != 'expired'"/>
                    <field name="state"
                           widget="statusbar"
                           options="{'clickable': 0}"
                           statusbar_visible="renewed"
                           invisible="state != 'renewed'"/>
                </header>
                <sheet>
                    <group>
                        <group string="Informations contrat">
                            <field name="name"/>
                            <field name="fournisseur_id"/>
                            <field name="type_contrat"/>
                            <field name="montant"/>
                        </group>
                        <group string="Dates et validité">
                            <field name="date_debut"/>
                            <field name="date_fin"/>
                            <field name="jours_restants" 
                                   readonly="1"/>
                        </group>
                    </group>
                    <group string="Équipements couverts">
                        <field name="equipement_ids" 
                               widget="many2many_tags"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_it_contrat" 
            model="ir.actions.act_window">
        <field name="name">Contrats</field>
        <field name="res_model">it.contrat</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_it_contrat_list"
              name="Tous les contrats"
              parent="menu_it_parc_contrats"
              action="action_it_contrat"
              sequence="10"/>

</odoo>
