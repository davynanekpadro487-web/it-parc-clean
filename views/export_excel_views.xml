<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Bouton export inventaire dans vue équipement -->
    <record id="view_it_equipement_form_excel"
            model="ir.ui.view">
        <field name="name">it.equipement.form.excel</field>
        <field name="model">it.equipement</field>
        <field name="inherit_id"
               ref="view_it_equipement_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <div class="o_form_buttons_view">
                    <button 
                        name="action_export_inventaire_excel"
                        string="📊 Exporter inventaire Excel"
                        type="object"
                        class="btn-secondary"/>
                    <button
                        name="action_export_couts_maintenance_excel"
                        string="📊 Exporter coûts maintenance"
                        type="object"
                        class="btn-secondary"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Bouton export contrats expirants -->
    <record id="view_it_contrat_form_excel"
            model="ir.ui.view">
        <field name="name">it.contrat.form.excel</field>
        <field name="model">it.contrat</field>
        <field name="inherit_id"
               ref="view_it_contrat_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <div class="o_form_buttons_view">
                    <button
                        name="action_export_contrats_excel"
                        string="📊 Exporter contrats expirants"
                        type="object"
                        class="btn-secondary"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Menu exports dans équipements -->
    <menuitem id="menu_it_exports"
              name="Exports"
              parent="menu_it_parc_root"
              sequence="60"/>

    <record id="action_export_inventaire"
            model="ir.actions.server">
        <field name="name">Exporter inventaire Excel</field>
        <field name="model_id"
               ref="model_it_equipement"/>
        <field name="binding_model_id"
               ref="model_it_equipement"/>
        <field name="state">code</field>
        <field name="code">
action = records.action_export_inventaire_excel()
        </field>
    </record>

</odoo>
