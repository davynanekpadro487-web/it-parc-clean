<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_it_alerte_list" 
            model="ir.ui.view">
        <field name="name">it.alerte.list</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <list string="Alertes"
                  decoration-danger="state == 'nouvelle'">
                <field name="name"/>
                <field name="type_alerte"/>
                <field name="equipement_id"/>
                <field name="contrat_id"/>
                <field name="date_expiration"/>
                <field name="jours_restants"
                       decoration-danger="jours_restants &lt; 30"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'nouvelle'"
                       decoration-success="state == 'traitee'"
                       decoration-muted="state == 'ignoree'"/>
            </list>
        </field>
    </record>

    <record id="view_it_alerte_form" 
            model="ir.ui.view">
        <field name="name">it.alerte.form</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <form string="Alerte">
                <header>
                    <field name="state"
                           widget="statusbar"
                           options="{'clickable': 1}"
                           statusbar_visible="traitee,ignoree"
                           invisible="state != 'nouvelle'"/>
                    <field name="state"
                           widget="statusbar"
                           options="{'clickable': 0}"
                           statusbar_visible="traitee"
                           invisible="state != 'traitee'"/>
                    <field name="state"
                           widget="statusbar"
                           options="{'clickable': 0}"
                           statusbar_visible="ignoree"
                           invisible="state != 'ignoree'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="type_alerte"/>
                            <field name="date_alerte"/>
                            <field name="date_expiration"/>
                            <field name="jours_restants"/>
                        </group>
                        <group>
                            <field name="equipement_id"/>
                            <field name="contrat_id"/>
                        </group>
                    </group>
                    <field name="message"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_it_alerte" 
            model="ir.actions.act_window">
        <field name="name">Alertes</field>
        <field name="res_model">it.alerte</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_it_alerte_list"
              name="Toutes les alertes"
              parent="menu_it_parc_alertes"
              action="action_it_alerte"
              sequence="10"/>

</odoo>
