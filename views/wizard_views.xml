<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard Réaffectation -->
    <record id="view_wizard_reaffectation_form"
            model="ir.ui.view">
        <field name="name">wizard.reaffectation.form</field>
        <field name="model">wizard.reaffectation</field>
        <field name="arch" type="xml">
            <form string="Réaffecter l'équipement">
                <group>
                    <field name="equipement_id"/>
                    <field name="ancien_employee_id" 
                           readonly="1"/>
                    <field name="nouvel_employee_id"/>
                    <field name="nouveau_department_id"/>
                    <field name="date_reaffectation"/>
                    <field name="motif"/>
                </group>
                <footer>
                    <button name="action_confirmer"
                            string="Confirmer la réaffectation"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_reaffectation"
            model="ir.actions.act_window">
        <field name="name">Réaffecter</field>
        <field name="res_model">wizard.reaffectation</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Wizard Renouvellement Contrat -->
    <record id="view_wizard_renouvellement_form"
            model="ir.ui.view">
        <field name="name">wizard.renouvellement.contrat.form</field>
        <field name="model">wizard.renouvellement.contrat</field>
        <field name="arch" type="xml">
            <form string="Renouveler le contrat">
                <group>
                    <field name="contrat_id"/>
                    <field name="ancienne_date_fin" 
                           readonly="1"/>
                    <field name="nouvelle_date_debut"/>
                    <field name="duree_mois"/>
                    <field name="nouvelle_date_fin" 
                           readonly="1"/>
                    <field name="nouveau_montant"/>
                </group>
                <footer>
                    <button name="action_renouveler"
                            string="Renouveler"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_renouvellement"
            model="ir.actions.act_window">
        <field name="name">Renouveler le contrat</field>
        <field name="res_model">wizard.renouvellement.contrat</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Wizard Scan Alertes -->
    <record id="view_wizard_scan_alertes_form"
            model="ir.ui.view">
        <field name="name">wizard.scan.alertes.form</field>
        <field name="model">wizard.scan.alertes</field>
        <field name="arch" type="xml">
            <form string="Scanner les alertes">
                <group>
                    <field name="delai_jours"/>
                    <field name="nb_alertes_creees" 
                           readonly="1"/>
                    <field name="rapport" 
                           readonly="1"
                           widget="text"/>
                </group>
                <footer>
                    <button name="action_scanner"
                            string="Lancer le scan"
                            type="object"
                            class="btn-primary"/>
                    <button string="Fermer"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_scan_alertes"
            model="ir.actions.act_window">
        <field name="name">Scanner les alertes</field>
        <field name="res_model">wizard.scan.alertes</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Bouton Réaffecter dans vue équipement -->
    <record id="view_it_equipement_form_reaffect"
            model="ir.ui.view">
        <field name="name">it.equipement.form.reaffect</field>
        <field name="model">it.equipement</field>
        <field name="inherit_id" 
               ref="view_it_equipement_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[last()]" 
                   position="after">
                <button name="%(action_wizard_reaffectation)s"
                        string="Réaffecter"
                        type="action"
                        class="btn-secondary"
                        invisible="state != 'affecte'"/>
            </xpath>
        </field>
    </record>

    <!-- Bouton Renouveler dans vue contrat -->
    <record id="view_it_contrat_form_renouveler"
            model="ir.ui.view">
        <field name="name">it.contrat.form.renouveler</field>
        <field name="model">it.contrat</field>
        <field name="inherit_id" 
               ref="view_it_contrat_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_wizard_renouvellement)s"
                        string="Renouveler"
                        type="action"
                        class="btn-primary"
                        context="{'default_contrat_id': id}"
                        invisible="state != 'expired'"/>
            </xpath>
        </field>
    </record>

    <!-- Menu Scan alertes -->
    <menuitem id="menu_it_scan_alertes"
              name="Scanner les alertes"
              parent="menu_it_parc_alertes"
              action="action_wizard_scan_alertes"
              sequence="20"/>

</odoo>
