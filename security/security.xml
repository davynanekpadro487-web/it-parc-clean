<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_it_parc" 
            model="ir.module.category">
        <field name="name">IT Parc</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_it_technicien" 
            model="res.groups">
        <field name="name">IT Technicien</field>
        <field name="category_id" 
               ref="module_category_it_parc"/>
    </record>

    <record id="group_it_manager" 
            model="res.groups">
        <field name="name">IT Manager</field>
        <field name="category_id" 
               ref="module_category_it_parc"/>
        <field name="implied_ids" 
               eval="[(4, ref('group_it_technicien'))]"/>
    </record>
</odoo>
