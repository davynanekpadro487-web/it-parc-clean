<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_it_equipement" 
            model="ir.sequence">
        <field name="name">IT Équipement</field>
        <field name="code">it.equipement</field>
        <field name="prefix">EQ/%(year)s/</field>
        <field name="padding">4</field>
    </record>
    <record id="seq_it_intervention" 
            model="ir.sequence">
        <field name="name">IT Intervention</field>
        <field name="code">it.intervention</field>
        <field name="prefix">INT/%(year)s/</field>
        <field name="padding">4</field>
    </record>
</odoo>
