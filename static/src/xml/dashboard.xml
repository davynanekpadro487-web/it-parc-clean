<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="it_parc.Dashboard">
    <div class="o_it_parc_dashboard">
        
        <!-- Header -->
        <div class="dashboard-header">
            <h1 style="color: #ffffff;">IT Parc — Tableau de Bord</h1>
            <p style="color: #ffffff;">TECHPARK CI</p>
        </div>

        <!-- Chargement -->
        <t t-if="!state.loaded">
            <div class="text-center p-5">
                <i class="fa fa-spinner fa-spin fa-3x"/>
                <p>Chargement des données...</p>
            </div>
        </t>

        <!-- Erreur -->
        <t t-if="state.error">
            <div class="alert alert-danger m-3">
                Erreur : <t t-esc="state.error"/>
            </div>
        </t>

        <!-- Contenu -->
        <t t-if="state.loaded and !state.error">
            <div class="dashboard-body">
                
                <!-- KPIs Grid (3x2) -->
                <div class="row m-2">
                    
                    <!-- KPI Total équipements -->
                    <div class="col-md-4 col-sm-6 mb-4">
                        <div class="card kpi-card text-center"
                              t-on-click="goToEquipements"
                              style="cursor:pointer;">
                            <div class="card-body p-0">
                                <div class="kpi-number">
                                    <t t-esc="state.kpis.total_equipements"/>
                                </div>
                                <div class="kpi-label">
                                    Total équipements
                                </div>
                                <i class="fa fa-desktop fa-2x kpi-icon"/>
                            </div>
                        </div>
                    </div>

                    <!-- KPI Affectés -->
                    <div class="col-md-4 col-sm-6 mb-4">
                        <div class="card kpi-card text-center"
                              t-on-click="goToEquipementsAffectes"
                              style="cursor:pointer;">
                            <div class="card-body p-0">
                                <div class="kpi-number">
                                    <t t-esc="state.kpis.par_etat.affecte"/>
                                </div>
                                <div class="kpi-label">
                                    Affectés
                                </div>
                                <i class="fa fa-check-circle fa-2x kpi-icon"/>
                            </div>
                        </div>
                    </div>

                    <!-- KPI En maintenance -->
                    <div class="col-md-4 col-sm-6 mb-4">
                        <div class="card kpi-card text-center"
                              t-on-click="goToEquipementsMaintenance"
                              style="cursor:pointer;">
                            <div class="card-body p-0">
                                <div class="kpi-number">
                                    <t t-esc="state.kpis.par_etat.maintenance"/>
                                </div>
                                <div class="kpi-label">
                                    En maintenance
                                </div>
                                <i class="fa fa-wrench fa-2x kpi-icon"/>
                            </div>
                        </div>
                    </div>

                    <!-- KPI Alertes actives -->
                    <div class="col-md-4 col-sm-6 mb-4">
                        <div class="card kpi-card text-center"
                              t-on-click="goToAlertes"
                              style="cursor:pointer;">
                            <div class="card-body p-0">
                                <div class="kpi-number">
                                    <t t-esc="state.kpis.alertes_nouvelles"/>
                                </div>
                                <div class="kpi-label">
                                    Alertes actives
                                </div>
                                <i class="fa fa-bell fa-2x kpi-icon"/>
                            </div>
                        </div>
                    </div>

                    <!-- KPI Garanties critiques -->
                    <div class="col-md-4 col-sm-6 mb-4">
                        <div class="card kpi-card text-center"
                              t-on-click="goToEquipementsGarantiesCritiques"
                              style="cursor:pointer;">
                            <div class="card-body p-0">
                                <div class="kpi-number">
                                    <t t-esc="state.kpis.garanties_critiques"/>
                                </div>
                                <div class="kpi-label">
                                    Garanties &lt; 30j
                                </div>
                                <i class="fa fa-shield fa-2x kpi-icon"/>
                            </div>
                        </div>
                    </div>

                    <!-- KPI Coût total -->
                    <div class="col-md-4 col-sm-6 mb-4">
                        <div class="card kpi-card text-center"
                              t-on-click="goToInterventions"
                              style="cursor:pointer;">
                            <div class="card-body p-0">
                                <div class="kpi-number">
                                    <t t-esc="formattedCoutTotalMaintenance"/>
                                </div>
                                <div class="kpi-label">
                                    Coût maintenance (F)
                                </div>
                                <i class="fa fa-money fa-2x kpi-icon"/>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Ligne de séparation élégante -->
                <div style="border-top: 1px solid #e5e7eb; margin: 25px 15px;"/>

                <!-- Graphiques (Côte à côte) -->
                <div class="row m-2">
                    <div class="col-md-6 col-12 mb-4">
                        <div class="card shadow-sm" style="border-radius: 12px; overflow: hidden; border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                            <div class="card-header"
                                 style="background:#ffffff;
                                        border-bottom: 1px solid #f0f0f0;
                                        padding: 15px;">
                                <h5 class="mb-0" style="font-size: 1rem; font-weight: 600; color: #333333;">
                                    📊 Répartition par catégorie
                                </h5>
                            </div>
                            <div class="card-body" style="position: relative; height: 320px; padding: 20px; background: white;">
                                <canvas t-ref="chartCategories"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-12 mb-4">
                        <div class="card shadow-sm" style="border-radius: 12px; overflow: hidden; border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                            <div class="card-header"
                                 style="background:#ffffff;
                                        border-bottom: 1px solid #f0f0f0;
                                        padding: 15px;">
                                <h5 class="mb-0" style="font-size: 1rem; font-weight: 600; color: #333333;">
                                    📈 Interventions par mois
                                </h5>
                            </div>
                            <div class="card-body" style="position: relative; height: 320px; padding: 20px; background: white;">
                                <canvas t-ref="chartInterventions"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bandeau alerte rouge pour les contrats critiques -->
                <t t-if="state.kpis.contrats_critiques > 0">
                    <div class="row m-2">
                        <div class="col-12">
                            <div class="alert-banner-bottom" t-on-click="goToContrats" style="cursor: pointer;">
                                <div class="d-flex align-items-center gap-3">
                                    <span class="banner-icon" style="font-size: 20px;">⚠️</span>
                                    <div class="banner-text">
                                        <strong>Attention :</strong> Il y a <t t-esc="state.kpis.contrats_critiques"/> contrat(s) de maintenance expirant bientôt (sous 60 jours).
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-danger banner-btn" style="border-radius: 6px; font-weight: 600; padding: 5px 15px;">
                                    Voir les contrats
                                </button>
                            </div>
                        </div>
                    </div>
                </t>

            </div>
        </t>
    </div>
</t>

</templates>
